# Renomme ce fichier en .env.local et remplis les valeurs depuis ton dashboard Supabase
# (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL publique de l'app (utilisée pour les redirections d'auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — clé serveur, JAMAIS exposée côté client.
# Crée-la sur https://platform.openai.com/api-keys (dépose au moins $5 de crédit).
OPENAI_API_KEY=sk-proj-...

# Supabase service_role — JAMAIS exposée côté client.
# Utilisée uniquement pour les opérations admin (suppression de compte RGPD).
# Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
